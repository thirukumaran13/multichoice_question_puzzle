{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Questions Array",
  "description": "Schema for a quiz question file",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["question", "choices", "chapter"],
    "additionalProperties": false,
    "properties": {
      "question": {
        "type": "string",
        "minLength": 5,
        "description": "The question text"
      },
      "choices": {
        "type": "array",
        "minItems": 2,
        "maxItems": 4,
        "items": { "type": "string", "minLength": 1 },
        "description": "Answer choices (2 to 4 options)"
      },
      "answer": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3,
        "default": 0,
        "description": "0-based index of the correct choice (optional; defaults to 0 — first choice)"
      },
      "chapter": {
        "type": "string",
        "minLength": 1,
        "description": "Chapter or topic the question belongs to"
      },
      "category": {
        "type": "string",
        "minLength": 1,
        "description": "Bloom's taxonomy category"
      },
      "complexity": {
        "type": "string",
        "enum": ["low", "medium","high"],
        "description": "Difficulty level of the question"
      },
      "reason": {
        "type": "string",
        "minLength": 1,
        "description": "Explanation for the correct answer (optional)"
      }
    }
  }
}
